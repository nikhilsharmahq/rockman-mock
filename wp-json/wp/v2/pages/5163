8221; column_padding_position=&#8221;all&#8221; centered_text=&#8221;true&#8221; background_color_opacity=&#8221;1&#8243; background_hover_color_opacity=&#8221;1&#8243; font_color=&#8221;#ffffff&#8221; column_shadow=&#8221;none&#8221; column_border_radius=&#8221;none&#8221; column_link_target=&#8221;_self&#8221; width=&#8221;1\/1&#8243; tablet_width_inherit=&#8221;default&#8221; column_border_width=&#8221;none&#8221; column_border_style=&#8221;solid&#8221; bg_image_animation=&#8221;none&#8221;][vc_column_text]\n<h2><strong>Testing Facilities<\/strong><\/h2>\n[\/vc_column_text][\/vc_column_inner][\/vc_row_inner]<div class=\"toggles accordion\" data-style=\"minimal\"><div class=\"toggle default\"><h3><a href=\"#\"><i class=\"icon-plus-sign\"><\/i>Metallurgy Lab<\/a><\/h3><div>[vc_column_text]<span style=\"font-weight: 400;\">As leading <\/span><b>industrial chain manufacturers in India<\/b><span style=\"font-weight: 400;\">, we maintain an in-house lab dedicated to strictly validating material grades. We analyse the chemical composition and grain structure of every alloy to ensure our <\/span><b>heavy-duty industrial chains<\/b><span style=\"font-weight: 400;\"> can withstand constant tension and high-load environments without fatigue.<\/span><\/p>\n<p>Our Testing Machines:<\/p>\n<ul>\n<li>Micro Hardness Tester<\/li>\n<li>Metallurgical Microscope<\/li>\n<li>Stereo Zoom Microscope<\/li>\n<li>Rockwell Hardness Tester<\/li>\n<li>Vickers Hardness Tester<\/li>\n<li>Grain Structure<\/li>\n<\/ul>\n[\/vc_column_text]<\/div><\/div><div class=\"toggle default\"><h3><a href=\"#\"><i class=\"icon-plus-sign\"><\/i>Heat Treatment<\/a><\/h3><div>[vc_row_inner column_margin=&#8221;default&#8221; text_align=&#8221;left&#8221;][vc_column_inner column_padding=&#8221;no-extra-padding&#8221; column_padding_position=&#8221;all&#8221; background_color_opacity=&#8221;1&#8243; background_hover_color_opacity=&#8221;1&#8243; column_shadow=&#8221;none&#8221; column_border_radius=&#8221;none&#8221; column_link_target=&#8221;_self&#8221; width=&#8221;1\/1&#8243; tablet_width_inherit=&#8221;default&#8221; column_border_width=&#8221;none&#8221; column_border_style=&#8221;solid&#8221; bg_image_animation=&#8221;none&#8221;][vc_column_text]<span style=\"font-weight: 400;\">We differentiate ourselves from other <\/span><b>industrial chain manufacturers<\/b><span style=\"font-weight: 400;\"> by utilising world-class <\/span><b>Continuous Hardening &amp; Tempering Furnaces<\/b><span style=\"font-weight: 400;\"> to achieve exact surface and core hardness.<\/span><\/p>\n<ul>\n<li><b>Plates<\/b><span style=\"font-weight: 400;\">: Our <\/span><b>through-hardening<\/b><span style=\"font-weight: 400;\"> process is designed to ensure uniform plate strength and high <\/span><b>fatigue resistance<\/b><span style=\"font-weight: 400;\">.<\/span><\/li>\n<li><b>Pins &amp; Bushes<\/b><span style=\"font-weight: 400;\">: We use a <\/span><b>SCADA-controlled<\/b> <b>Case Carbonitriding<\/b><span style=\"font-weight: 400;\"> process to create a high-wear surface with a tough, impact-resistant core.<\/span><\/li>\n<li><b>Rollers<\/b><span style=\"font-weight: 400;\">: Specialised <\/span><b>Case Carburising<\/b><span style=\"font-weight: 400;\"> process provides the necessary <\/span><b>compression strength<\/b><span style=\"font-weight: 400;\"> to survive heavy shock loads.<\/span><\/li>\n<\/ul>\n[\/vc_column_text][\/vc_column_inner][\/vc_row_inner]<\/div><\/div><div class=\"toggle default\"><h3><a href=\"#\"><i class=\"icon-plus-sign\"><\/i>Tool Room<\/a><\/h3><div>[vc_row_inner column_margin=&#8221;default&#8221; text_align=&#8221;left&#8221;][vc_column_inner column_padding=&#8221;no-extra-padding&#8221; column_padding_position=&#8221;all&#8221; background_color_opacity=&#8221;1&#8243; background_hover_color_opacity=&#8221;1&#8243; column_shadow=&#8221;none&#8221; column_border_radius=&#8221;none&#8221; column_link_target=&#8221;_self&#8221; width=&#8221;1\/1&#8243; tablet_width_in